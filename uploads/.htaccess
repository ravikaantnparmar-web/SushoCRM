# Prevent execution of any scripts in the uploads directory
<FilesMatch "\.(php|php3|php4|php5|php7|php8|phtml|pl|py|jsp|asp|htm|html|shtml|sh|cgi|exe|bat|cmd)$">
    SetHandler text/plain
    ForceType text/plain
</FilesMatch>

# Prevent directory listing
Options -Indexes

# Disable PHP engine
<IfModule mod_php5.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
